From 4bcd2aa43e0b7a15562f43d2966d5353307707ee Mon Sep 17 00:00:00 2001
From: Alfred Chen <cchalpha@gmail.com>
Date: Thu, 7 Nov 2024 03:21:39 +0000
Subject: [PATCH 518/520] sched/alt: Fix WARN_ON_ONCE in migrate_enable()

In Project C implementation, do_set_cpus_allowed() is a code path
without task migration disabled awareness.
---
 kernel/sched/alt_core.c | 25 ++++++++++++++++++-------
 1 file changed, 18 insertions(+), 7 deletions(-)

diff --git a/kernel/sched/alt_core.c b/kernel/sched/alt_core.c
index 9c6e28362182..8647017972cf 100644
--- a/kernel/sched/alt_core.c
+++ b/kernel/sched/alt_core.c
@@ -1510,6 +1510,10 @@ void migrate_enable(void)
 	 * __set_cpus_allowed_ptr(SCA_MIGRATE_ENABLE) doesn't schedule().
 	 */
 	guard(preempt)();
+	/*
+	 * Assumption: current should be running on allowed cpu
+	 */
+	WARN_ON_ONCE(!cpumask_test_cpu(smp_processor_id(), &p->cpus_mask));
 	if (p->cpus_ptr != &p->cpus_mask)
 		__do_set_cpus_ptr(p, &p->cpus_mask);
 	/*
@@ -1523,6 +1527,15 @@ void migrate_enable(void)
 }
 EXPORT_SYMBOL_GPL(migrate_enable);
 
+static void __migrate_force_enable(struct task_struct *p, struct rq *rq)
+{
+	if (likely(p->cpus_ptr != &p->cpus_mask))
+		__do_set_cpus_ptr(p, &p->cpus_mask);
+	p->migration_disabled = 0;
+	/* When p is migrate_disabled, rq->lock should be held */
+	rq->nr_pinned--;
+}
+
 static inline bool rq_has_pinned_tasks(struct rq *rq)
 {
 	return rq->nr_pinned;
@@ -1703,6 +1716,9 @@ void do_set_cpus_allowed(struct task_struct *p, const struct cpumask *new_mask)
 
 	__do_set_cpus_allowed(p, &ac);
 
+	if (is_migration_disabled(p) && !cpumask_test_cpu(task_cpu(p), &p->cpus_mask))
+		__migrate_force_enable(p, task_rq(p));
+
 	/*
 	 * Because this is called with p->pi_lock held, it is not possible
 	 * to use kfree() here (when PREEMPT_RT=y), therefore punt to using
@@ -1998,13 +2014,8 @@ static int affine_move_task(struct rq *rq, struct task_struct *p, int dest_cpu,
 {
 	/* Can the task run on the task's current CPU? If so, we're done */
 	if (!cpumask_test_cpu(task_cpu(p), &p->cpus_mask)) {
-		if (p->migration_disabled) {
-			if (likely(p->cpus_ptr != &p->cpus_mask))
-				__do_set_cpus_ptr(p, &p->cpus_mask);
-			p->migration_disabled = 0;
-			/* When p is migrate_disabled, rq->lock should be held */
-			rq->nr_pinned--;
-		}
+		if (is_migration_disabled(p))
+			__migrate_force_enable(p, rq);
 
 		if (task_on_cpu(p) || READ_ONCE(p->__state) == TASK_WAKING) {
 			struct migration_arg arg = { p, dest_cpu };
-- 
