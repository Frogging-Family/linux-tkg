 			cpumask_copy(tmp, cpu_possible_mask);
 			cpumask_clear_cpu(cpu, tmp);
@@ -5898,6 +5898,8 @@ static void sched_init_topology_cpumask(void)
 
 		chk = &(per_cpu(sched_cpu_affinity_masks, cpu)[0]);
 
